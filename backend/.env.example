# Infrastructure
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_scalping
REDIS_URL=redis://localhost:6379/0
API_PORT=8000
AUTH_TOKEN=your-secret-token-here

# Trading parameters
LOT_SIZE=0.10
STOP_LOSS_POINTS=100
TAKE_PROFIT_POINTS=150
MAX_DAILY_LOSS_PCT=3.0

# Indicator parameters
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MAX_SPREAD_POINTS=40

# Session times (UTC hours)
LONDON_START_HOUR=8
LONDON_END_HOUR=16
NY_START_HOUR=13
NY_END_HOUR=21
